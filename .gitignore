# Root .gitignore for Text Correction Application

# Environment files - CRITICAL: Never commit these
.env
.env.local
.env.*.local
*.env

# IDE and Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS Files
Thumbs.db
Desktop.ini

# Logs
*.log
logs/
*.log.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
.pytest_cache/
.coverage
.tox/

# Node
node_modules/
dist/
dist-ssr/
build/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
*.cache
.cache/

# Secrets and credentials - IMPORTANT
*secret*
*credential*
*password*
*.pem
*.key
*.p12
*.pfx
!backend/.env.example
!**/README.md
!**/package.json
!**/requirements.txt
